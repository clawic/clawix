<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Clawix.App.Views.Settings.UpdatesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <ScrollViewer Padding="24">
    <StackPanel Spacing="16" MaxWidth="640">
      <TextBlock Text="Updates" FontSize="22" FontWeight="SemiBold" />
      <TextBlock x:Name="VersionText" Opacity="0.7" />
      <Button Content="Check for updates now" Click="Check_Click" Style="{ThemeResource AccentButtonStyle}" />
      <ToggleSwitch Header="Auto-install updates" IsOn="True" />
      <Expander Header="Advanced" IsExpanded="False">
        <StackPanel Spacing="12" Padding="0,8,0,0">
          <TextBox Header="Appcast URL" IsReadOnly="True" />
          <ToggleSwitch Header="Subscribe to beta channel" />
        </StackPanel>
      </Expander>
    </StackPanel>
  </ScrollViewer>
</Page>
