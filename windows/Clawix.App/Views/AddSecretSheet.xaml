<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="Clawix.App.Views.AddSecretSheet"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Add secret"
    PrimaryButtonText="Save"
    SecondaryButtonText="Cancel"
    DefaultButton="Primary">
  <StackPanel Spacing="8">
    <TextBox x:Name="LabelBox" PlaceholderText="Label (e.g. OPENAI_API_KEY)" />
    <PasswordBox x:Name="ValueBox" PlaceholderText="Secret value" />
    <ComboBox x:Name="KindBox" Header="Kind">
      <ComboBoxItem Content="API key" />
      <ComboBoxItem Content="Token" />
      <ComboBoxItem Content="Generic" />
    </ComboBox>
  </StackPanel>
</ContentDialog>
