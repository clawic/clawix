.DS_Store
.build/
ios/.build/
ios/.build-test/
macos/.build/
macos/build/
macos/artifacts/
test-results/
test-results-*/
artifacts/
coverage/
.tmp/
.tmp-*/
packages/*/.build/
*.app/
*.xcodeproj/
DerivedData/
.swiftpm/
xcuserdata/
