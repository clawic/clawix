<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Clawix.App.Views.FindBarView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Border Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="6" Padding="6">
    <StackPanel Orientation="Horizontal" Spacing="6">
      <TextBox x:Name="QueryBox" PlaceholderText="Find" Width="220" />
      <Button Content="Prev" />
      <Button Content="Next" />
      <TextBlock x:Name="MatchCount" VerticalAlignment="Center" Opacity="0.6" />
      <Button Content="✕" />
    </StackPanel>
  </Border>
</UserControl>
