{
  "schemaVersion": 1,
  "program": "code-hygiene",
  "tools": {
    "knip": {
      "version": "6.14.0",
      "mode": "pinned-dev-dependency-report-only",
      "runner": "scripts/code-hygiene-knip.mjs",
      "config": "web/knip.json",
      "reportJson": "docs/code-hygiene-knip-report.json",
      "reportMarkdown": "docs/code-hygiene-knip-report.md",
      "destructiveDefault": false,
      "purpose": "TypeScript and JavaScript unused files, exports, dependencies, enum members, and duplicate candidates after entrypoint calibration."
    },
    "periphery": {
      "version": "3.7.4",
      "mode": "versioned-homebrew-report-only-until-calibrated",
      "runner": "scripts/code-hygiene-periphery.mjs",
      "reportJson": "docs/code-hygiene-periphery-report.json",
      "reportMarkdown": "docs/code-hygiene-periphery-report.md",
      "install": "brew install periphery",
      "destructiveDefault": false,
      "purpose": "Swift unused declaration scanner with public API, SwiftUI, Codable, selector, resource, and dynamic-use retain rules."
    }
  }
}
