<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Clawix.App.Views.ChatView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Clawix.Core.Models"
    xmlns:views="using:Clawix.App.Views">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Padding="16,12" BorderThickness="0,0,0,1"
            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
      <TextBlock x:Name="TitleText" Text="{x:Bind Title, Mode=OneWay}"
                 FontWeight="SemiBold" FontSize="16" />
    </Border>

    <ListView Grid.Row="1" x:Name="MessageList"
              ItemsSource="{x:Bind Messages, Mode=OneWay}"
              IsItemClickEnabled="False" SelectionMode="None"
              Padding="16,8">
      <ListView.ItemTemplate>
        <DataTemplate x:DataType="models:WireMessage">
          <StackPanel Margin="0,4">
            <TextBlock Text="{x:Bind Role}" FontSize="11" Opacity="0.5" />
            <TextBlock Text="{x:Bind Content}" TextWrapping="Wrap" />
          </StackPanel>
        </DataTemplate>
      </ListView.ItemTemplate>
    </ListView>

    <views:ComposerView Grid.Row="2" x:Name="Composer" />
  </Grid>
</UserControl>
