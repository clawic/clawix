.DS_Store
.build/
ios/.build/
ios/.build-test/
macos/.build/
macos/build/
macos/artifacts/
test-results/
test-results-*/
artifacts/
coverage/
.tmp/
.tmp-*/
docs/codebase-manifest.json
packages/*/.build/
*.xcodeproj/
DerivedData/
.swiftpm/
xcuserdata/
*.swp
*.log
*.out
*.err

# Maintainer signing config. Never commit a real codesign identity.
.signing.env
.signing.env.local
.signing.env.*
!.signing.env.example
.release-notes.md

# Generated web SPA bundle copied into the bridged helper's SwiftPM resources.
macos/Helpers/Bridged/Sources/clawix-bridge/Resources/web-dist/**
!macos/Helpers/Bridged/Sources/clawix-bridge/Resources/web-dist/
!macos/Helpers/Bridged/Sources/clawix-bridge/Resources/web-dist/.gitkeep

# Generated from macOS Sources/Clawix/Resources/Localizable.xcstrings.
macos/Sources/Clawix/Resources/*.lproj/Localizable.strings
macos/Sources/Clawix/Resources/*.lproj/Localizable.stringsdict
