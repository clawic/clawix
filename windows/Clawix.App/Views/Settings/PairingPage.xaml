<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Clawix.App.Views.Settings.PairingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:Clawix.App.Views">
  <ScrollViewer Padding="24">
    <StackPanel Spacing="16">
      <TextBlock Text="Pair iPhone" FontSize="22" FontWeight="SemiBold" />
      <views:PairingView />
      <Expander Header="Advanced" IsExpanded="False">
        <StackPanel Spacing="12" Padding="0,8,0,0">
          <Button Content="Rotate bearer token" Click="Rotate_Click" />
          <Button Content="Copy QR JSON" Click="CopyQr_Click" />
          <ToggleSwitch Header="Publish via Bonjour" IsOn="True" />
        </StackPanel>
      </Expander>
    </StackPanel>
  </ScrollViewer>
</Page>
