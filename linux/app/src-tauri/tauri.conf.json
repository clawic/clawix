{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Clawix",
  "version": "0.1.0",
  "identifier": "com.example.clawix.linux",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Clawix",
        "width": 1280,
        "height": 800,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "fullscreen": false,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "titleBarStyle": "Visible"
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: ipc: ws://127.0.0.1:* ws://localhost:*; img-src 'self' data: tauri: asset: https://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src 'self' tauri: ipc: ws://127.0.0.1:* ws://localhost:* https://api.github.com https://*.clawix.com"
    },
    "trayIcon": {
      "id": "main-tray",
      "iconPath": "icons/tray.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "category": "Productivity",
    "shortDescription": "Companion desktop client for Clawix",
    "longDescription": "Clawix is the desktop companion that pairs with your phone, surfaces dictation, and orchestrates AI workflows.",
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0", "libayatana-appindicator3-1", "libssl3"],
        "section": "utils",
        "priority": "optional"
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://clawix.com/updates/linux/{{target}}/{{current_version}}"
      ],
      "dialog": false,
      "pubkey": "REPLACE_WITH_PUBLIC_KEY_AT_RELEASE_TIME"
    }
  }
}
