      "excludeScopes": ["macos/Sources/Clawix/AutomationsView.swift", "macos/Sources/Clawix/PlanQuestionCard.swift"],
      "classification": "pattern",
      "patterns": ["chat-surface", "composer-chrome", "sidebar-row", "sheet-chrome", "toast", "search-field", "icon-chip-button", "right-sidebar-surface", "entity-card"],
      "reason": "Root Swift files include app chrome, shared controls, icons, search, sheets, toast, and conversation support surfaces."
