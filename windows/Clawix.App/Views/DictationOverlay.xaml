<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Clawix.App.Views.DictationOverlay"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Border Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}"
          CornerRadius="24" Padding="20"
          BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
          BorderThickness="1">
    <StackPanel Orientation="Horizontal" Spacing="12">
      <FontIcon Glyph="&#xE720;" FontSize="20" />
      <TextBlock x:Name="Status" Text="Listening..." VerticalAlignment="Center" />
      <Button x:Name="StopBtn" Content="Stop" Click="Stop_Click" />
    </StackPanel>
  </Border>
</UserControl>
