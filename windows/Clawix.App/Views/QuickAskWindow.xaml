<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Clawix.App.Views.QuickAskWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Quick Ask">
  <Grid Padding="16" RowSpacing="8">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <TextBox Grid.Row="0" x:Name="QueryBox" PlaceholderText="Ask anything..." />
    <ScrollViewer Grid.Row="1">
      <TextBlock x:Name="ResultText" TextWrapping="Wrap" />
    </ScrollViewer>
    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
      <Button Content="📷" />
      <Button Content="📎" />
      <Button Content="Send" Style="{ThemeResource AccentButtonStyle}" />
    </StackPanel>
  </Grid>
</Window>
