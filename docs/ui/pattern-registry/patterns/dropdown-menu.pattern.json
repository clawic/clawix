{
  "schemaVersion": 1,
  "id": "dropdown-menu",
  "status": "canonical",
  "platforms": ["macos", "ios", "android", "web"],
  "mutationClass": ["visual-ui", "copy-ui", "functional-ui"],
  "canonicalReferences": [
    "STYLE.md#63-dropdowns--popovers",
    "macos/Sources/Clawix/ComposerMenus.swift",
    "macos/Sources/Clawix/Settings/SettingsView+Controls.swift",
    "web/src/components/ui/menu.tsx"
  ],
  "states": ["idle", "hover-or-highlight", "focused", "pressed", "disabled", "selected", "busy", "error"],
  "geometry": {
    "cornerRadius": 12,
    "borderWidth": 0.5,
    "containerVerticalPadding": 4,
    "rowHorizontalPadding": 9,
    "rowVerticalPadding": 6,
    "rowHoverCornerRadius": 8,
    "rowHoverHorizontalInset": 4,
    "submenuGap": 6,
    "rowIconWidth": 18
  },
  "copy": {
    "labelMaxWords": 4,
    "tooltipMaxWords": 12,
    "visibleNamesAreCanon": true
  },
  "componentExtraction": {
    "policy": "required-when-repeated-with-state",
    "api": "limited-slots"
  },
  "validation": {
    "public": ["node scripts/ui_governance_guard.mjs"],
    "private": ["dropdown state screenshots and geometry baseline"]
  }
}
