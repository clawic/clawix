// Build configuration for the Clawix iOS companion. The bundle id and
// development team are NEVER committed: they are injected at build time
// from the workspace-private `.signing.env`. The script
// `ios/scripts/dev.sh` reads that file and forwards the values via
// `xcodebuild` overrides, so the values fall through to these
// fallbacks only when someone runs `xcodebuild` by hand without the
// helper script.

PRODUCT_BUNDLE_IDENTIFIER = $(BUNDLE_ID_IOS:default=com.example.clawix)
DEVELOPMENT_TEAM =
CODE_SIGN_STYLE = Automatic

IPHONEOS_DEPLOYMENT_TARGET = 26.0
SWIFT_VERSION = 5.9
TARGETED_DEVICE_FAMILY = 1
SUPPORTS_MACCATALYST = NO

// `wss://` to a self-signed cert on a LAN host is what we need; ATS
// allows it once we opt into NSAllowsLocalNetworking in Info.plist.
ASSETCATALOG_COMPILER_APPICON_NAME = AppIcon
ENABLE_BITCODE = NO
SWIFT_TREAT_WARNINGS_AS_ERRORS = NO

// Keep the simulator and device builds in sync on the dark identity
// inherited from macOS Clawix. Forced dark prevents the system from
// flipping to light when the device is in light mode while the
// pairing UI is dark-first by design.
UIUserInterfaceStyle = Dark
