{
  "name": "@clawix/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Clawix web client. Third bridge client (after macOS GUI and iOS) that talks to clawix-bridged via WebSocket.",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "check:wire": "tsx scripts/check-wire-parity.ts"
  },
  "dependencies": {
    "@tanstack/react-router": "^1.95.0",
    "figma-squircle": "^1.0.0",
    "framer-motion": "^11.15.0",
    "hash-wasm": "^4.12.0",
    "lucide-react": "^0.469.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.4",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
