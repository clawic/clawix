<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Clawix.App.Views.Settings.AccountPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <ScrollViewer Padding="24">
    <StackPanel Spacing="16" MaxWidth="640">
      <TextBlock Text="Account" FontSize="22" FontWeight="SemiBold" />
      <InfoBar IsOpen="True" Severity="Informational" Title="Signed in" Message="Connected to Codex." IsClosable="False" />
      <Button Content="Sign out" />
      <Expander Header="Advanced" IsExpanded="False">
        <StackPanel Spacing="12" Padding="0,8,0,0">
          <Button Content="View access tokens" />
          <Button Content="Rotate refresh token" />
        </StackPanel>
      </Expander>
    </StackPanel>
  </ScrollViewer>
</Page>
