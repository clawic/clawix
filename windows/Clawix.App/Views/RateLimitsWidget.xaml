<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Clawix.App.Views.RateLimitsWidget"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Border Padding="8" CornerRadius="6"
          Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}">
    <StackPanel Spacing="6">
      <TextBlock Text="Usage" Style="{ThemeResource ClawixCaption}" />
      <Grid ColumnSpacing="6">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="80" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0" Text="Primary" Style="{ThemeResource ClawixCaption}" />
        <ProgressBar Grid.Column="1" x:Name="PrimaryBar" Maximum="100" Value="0" />
        <TextBlock Grid.Column="2" x:Name="PrimaryText" Text="0%" Style="{ThemeResource ClawixCaption}" />
      </Grid>
      <Grid ColumnSpacing="6">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="80" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0" Text="Secondary" Style="{ThemeResource ClawixCaption}" />
        <ProgressBar Grid.Column="1" x:Name="SecondaryBar" Maximum="100" Value="0" />
        <TextBlock Grid.Column="2" x:Name="SecondaryText" Text="0%" Style="{ThemeResource ClawixCaption}" />
      </Grid>
      <TextBlock x:Name="CreditsText" Style="{ThemeResource ClawixCaption}" Visibility="Collapsed" />
    </StackPanel>
  </Border>
</UserControl>
