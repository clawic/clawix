    "Ask Clawix anything. Type @ to mention files": {
      "localizations": {
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Pregúntale a Clawix cualquier cosa. Escribe @ para usar plugins o mencionar archivos"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Ask Clawix anything. Type @ to mention files"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Posez n’importe quelle question à Clawix. Tapez @ pour utiliser des extensions ou mentionner des fichiers"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Frag Clawix alles. Tippe @, um Erweiterungen zu nutzen oder Dateien zu erwähnen"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Chiedi a Clawix qualsiasi cosa. Digita @ per usare i plugin o citare file"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Pergunte qualquer coisa ao Clawix. Digite @ para usar plugins ou mencionar arquivos"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Clawixに何でも聞いてください。@ でプラグインやファイル参照を呼び出せます"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "向 Clawix 提任何问题。输入 @ 使用插件或引用文件"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Clawix에게 무엇이든 물어보세요. @를 입력해 플러그인을 사용하거나 파일을 언급하세요"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Спросите Clawix о чём угодно. Введите @, чтобы использовать плагины или упомянуть файлы"
          }
        }
      }
    },
