    "pressed": ["press", "Pressed", "onTap", "Button(", "click", "onClick", "clickable", "tap"],
    "disabled": ["disabled", "isEnabled", "enabled"],
    "selected": ["selected", "selection", "isSelected", "current", "active"],
    "busy": ["loading", "busy", "Progress", "spinner", "pending", "isLoading", "ProgressIndicator"],
    "error": ["error", "failed", "failure", "alert", "catch"]
