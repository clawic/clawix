    "Pick a Whisper size to start. Tiny is fast and runs anywhere; Small balances quality and disk; Large is the most accurate. You can change this later from Settings → Voice to Text.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pick a Whisper size to start. Tiny is fast and runs anywhere; Small balances quality and disk; Large is the most accurate. You can change this later from Settings → Voice to Text."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige un tamaño de Whisper para empezar. Tiny es rápido y funciona en cualquier sitio; Small equilibra calidad y disco; Large es el más preciso. Puedes cambiarlo más tarde desde Ajustes → Voice to Text."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Pick a Whisper size to start. Tiny is fast and runs anywhere; Small balances quality and disk; Large is the most accurate. You can change this later from Settings → Voice to Text."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pick a Whisper size to start. Tiny is fast and runs anywhere; Small balances quality and disk; Large is the most accurate. You can change this later from Settings → Voice to Text."
          }
