<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Typography. Letter-spacing tightened (-1%) on headlines, body left
       at the system default. Mirrors the Mac SF Pro tracking. -->
  <Style x:Key="ClawixHeadline" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="Segoe UI Variable" />
    <Setter Property="FontSize" Value="24" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="CharacterSpacing" Value="-10" />
  </Style>
  <Style x:Key="ClawixSubhead" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="Segoe UI Variable" />
    <Setter Property="FontSize" Value="18" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="CharacterSpacing" Value="-5" />
  </Style>
  <Style x:Key="ClawixBody" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="Segoe UI Variable" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="LineHeight" Value="20" />
  </Style>
  <Style x:Key="ClawixCaption" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="Segoe UI Variable" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="Opacity" Value="0.6" />
  </Style>

  <!-- Cards / surface tokens. Match the Fluent Design surface stack. -->
  <Thickness x:Key="CardPadding">16</Thickness>
  <CornerRadius x:Key="CardCornerRadius">8</CornerRadius>

  <!-- Animations. -->
  <Duration x:Key="ClawixFastDuration">0:0:0.15</Duration>
  <Duration x:Key="ClawixDuration">0:0:0.25</Duration>
  <Duration x:Key="ClawixSlowDuration">0:0:0.40</Duration>
</ResourceDictionary>
