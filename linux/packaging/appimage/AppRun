#!/usr/bin/env bash
# AppRun for Clawix.AppDir. Sets the AppImage bin paths, exports the
# daemon location for the GUI's service_manager, then exec's the shell.
HERE="$(dirname "$(readlink -f "${0}")")"
export PATH="$HERE/usr/bin:$HERE/usr/lib/clawix:$PATH"
export LD_LIBRARY_PATH="$HERE/usr/lib:$HERE/usr/lib/clawix:${LD_LIBRARY_PATH:-}"
export CLAWIX_BRIDGE_BIN="$HERE/usr/lib/clawix/clawix-bridge"
exec "$HERE/usr/bin/clawix" "$@"
