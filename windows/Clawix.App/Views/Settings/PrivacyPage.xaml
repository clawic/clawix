<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Clawix.App.Views.Settings.PrivacyPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <ScrollViewer Padding="24">
    <StackPanel Spacing="16" MaxWidth="640">
      <TextBlock Text="Privacy" FontSize="22" FontWeight="SemiBold" />
      <ToggleSwitch Header="Send crash reports" />
      <ToggleSwitch Header="Share anonymous usage telemetry" />
      <ToggleSwitch Header="Allow training on conversations" IsOn="False" IsEnabled="False" />
      <Expander Header="Advanced" IsExpanded="False">
        <StackPanel Spacing="12" Padding="0,8,0,0">
          <Button Content="Export all my data..." />
          <Button Content="Erase all local data..." Style="{ThemeResource AccentButtonStyle}" />
        </StackPanel>
      </Expander>
    </StackPanel>
  </ScrollViewer>
</Page>
