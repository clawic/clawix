{
  "schemaVersion": 1,
  "status": "active",
  "platforms": ["macos", "ios", "android", "web"],
  "visualAuthorizationPolicy": {
    "mode": "private-allowlist",
    "privateAssignment": "outside-public-repo",
    "publicSignalEnv": "CLAWIX_UI_VISUAL_AUTHORIZED",
    "publicSignalValue": "1"
  },
  "mutationClasses": ["functional-ui", "visual-ui", "copy-ui", "mechanical-equivalent-refactor"],
  "restrictedChangeKinds": [
    "color",
    "spacing",
    "size",
    "icon",
    "layout",
    "animation",
    "microcopy",
    "visible-name",
    "ordering",
    "hierarchy",
    "typography"
  ],
  "requiredInteractiveStates": [
    "idle",
    "hover-or-highlight",
    "focused",
    "pressed",
    "disabled",
    "selected",
    "busy",
    "error"
  ],
  "publicChecks": [
    "registry-completeness",
    "debt-baseline-shape",
    "debt-report-coverage",
    "protected-surface-shape",
    "protected-surface-freeze-contract-check",
    "canon-promotion-record-check",
    "exception-expiry",
    "exception-registry-check",
    "geometry-contract-shape",
    "geometry-contract-clause-check",
    "implementation-evidence-contract-check",
    "state-coverage-source-evidence",
    "rendered-geometry-manifest-shape",
    "copy-governance-contract-check",
    "component-extraction-policy-check",
    "mechanical-equivalence-policy-check",
    "visual-scope-policy-check",
    "visual-detector-policy-check",
    "visual-model-allowlist-check",
    "visual-guard-failure-self-test",
    "private-baseline-manifest-shape",
    "private-visual-validation-manifest-shape",
    "performance-budget-platform-coverage",
    "unauthorized-visual-diff"
  ],
  "privateArtifactsPolicy": {
    "screenshots": "private",
    "goldenBaselines": "private",
    "publicRepoStores": ["manifest", "metadata", "tolerance", "command", "hash"]
  }
}
