<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Clawix.App.Views.Settings.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <ScrollViewer Padding="24">
    <StackPanel Spacing="16" MaxWidth="640">
      <TextBlock Text="About Clawix" FontSize="22" FontWeight="SemiBold" />
      <TextBlock x:Name="VersionText" />
      <HyperlinkButton Content="Open source license" />
      <HyperlinkButton Content="Privacy policy" />
      <HyperlinkButton Content="Report an issue" />
      <Expander Header="Advanced" IsExpanded="False">
        <StackPanel Spacing="12" Padding="0,8,0,0">
          <Button Content="Open log folder" Click="OpenLogs_Click" />
          <Button Content="Run diagnostics" />
          <Button Content="Copy diagnostics report to clipboard" />
        </StackPanel>
      </Expander>
    </StackPanel>
  </ScrollViewer>
</Page>
